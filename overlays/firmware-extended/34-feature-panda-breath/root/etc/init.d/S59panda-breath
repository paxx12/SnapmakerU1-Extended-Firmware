#!/bin/sh

PANDA_BREATH_MODULE="/usr/local/share/firmware-config/tweaks/klipper/panda_breath.py"
PANDA_BREATH_TEMPLATE="/usr/local/share/firmware-config/tweaks/klipper/panda_breath.cfg"
PANDA_BREATH_HEATER="/usr/local/share/firmware-config/tweaks/klipper/panda_breath_heater.cfg"
KLIPPER_EXTRAS_LINK="/home/lava/klipper/klippy/extras/panda_breath.py"
CFG="/oem/printer_data/config/extended/klipper/panda_breath.cfg"
CFG_HEATER="/oem/printer_data/config/extended/klipper/panda_breath_heater.cfg"
CFG_DIR="/oem/printer_data/config/extended/klipper"

ensure_user_config() {
    mkdir -p "$CFG_DIR"

    if [ ! -f "$CFG" ]; then
        echo "Installing Panda Breath user config..."
        cp "$PANDA_BREATH_TEMPLATE" "$CFG"
    fi

    chown lava:lava "$CFG"
    chmod 0644 "$CFG"
}

ensure_module_link() {
    mkdir -p "$(dirname "$KLIPPER_EXTRAS_LINK")"

    if [ ! -f "$PANDA_BREATH_MODULE" ]; then
        echo "Panda Breath module template is missing; removing stale Klipper links."
        rm -f "$KLIPPER_EXTRAS_LINK" "$CFG_HEATER"
        return 1
    fi

    echo "Ensuring Panda Breath module symlink..."
    ln -sf "$PANDA_BREATH_MODULE" "$KLIPPER_EXTRAS_LINK"
}

cleanup_disabled_state() {
    rm -f "$CFG_HEATER" "$KLIPPER_EXTRAS_LINK"
}

start() {
    if [ ! -f "$CFG" ] && [ ! -L "$CFG" ]; then
        cleanup_disabled_state
        return 0
    fi

    ensure_user_config

    if ensure_module_link; then
        echo "Ensuring Panda Breath heater config symlink..."
        ln -sf "$PANDA_BREATH_HEATER" "$CFG_HEATER"
    else
        echo "Skipping Panda Breath heater config until module link is ready."
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        cleanup_disabled_state
        ;;
    restart|reload)
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
